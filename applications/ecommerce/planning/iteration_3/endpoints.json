{
  "metadata": {
    "description": "Comprehensive root endpoints for e-commerce microservice architecture",
    "version": "iteration_3",
    "total_endpoints": 34,
    "api_services": 8
  },
  "endpoints": {
    "Catalog-API": {
      "description": "Product catalog browsing and discovery endpoints",
      "base_path": "/catalog",
      "endpoints": [
        {
          "method": "GET",
          "path": "/products",
          "description": "Browse product catalog with filtering and pagination",
          "parameters": ["category", "price_range", "page", "limit"]
        },
        {
          "method": "GET", 
          "path": "/products/{product_id}",
          "description": "Get detailed product information including variants and pricing",
          "parameters": ["product_id"]
        },
        {
          "method": "GET",
          "path": "/products/{product_id}/variants",
          "description": "Get available product variants (size, color, configuration)",
          "parameters": ["product_id"]
        },
        {
          "method": "GET",
          "path": "/products/{product_id}/availability",
          "description": "Check product availability across warehouses",
          "parameters": ["product_id", "variant_id", "quantity"]
        },
        {
          "method": "GET",
          "path": "/categories",
          "description": "Get product category hierarchy and taxonomy",
          "parameters": ["depth", "include_counts"]
        }
      ]
    },
    "Cart-API": {
      "description": "Shopping cart management endpoints",
      "base_path": "/cart",
      "endpoints": [
        {
          "method": "GET",
          "path": "/",
          "description": "Get current cart contents with pricing",
          "parameters": ["user_id", "session_id"]
        },
        {
          "method": "POST",
          "path": "/items",
          "description": "Add item to cart with quantity and variant selection",
          "parameters": ["product_id", "variant_id", "quantity"]
        },
        {
          "method": "PUT",
          "path": "/items/{item_id}",
          "description": "Update cart item quantity or variant",
          "parameters": ["item_id", "quantity", "variant_id"]
        },
        {
          "method": "DELETE",
          "path": "/items/{item_id}",
          "description": "Remove item from cart",
          "parameters": ["item_id"]
        },
        {
          "method": "POST",
          "path": "/validate",
          "description": "Validate cart contents for availability and pricing",
          "parameters": []
        }
      ]
    },
    "Checkout-API": {
      "description": "Checkout process and payment endpoints",
      "base_path": "/checkout",
      "endpoints": [
        {
          "method": "POST",
          "path": "/session",
          "description": "Initialize checkout session from cart",
          "parameters": ["cart_id", "shipping_address_id", "billing_address_id"]
        },
        {
          "method": "GET",
          "path": "/session/{session_id}",
          "description": "Get checkout session details with pricing breakdown",
          "parameters": ["session_id"]
        },
        {
          "method": "PUT",
          "path": "/session/{session_id}/shipping",
          "description": "Update shipping address and method",
          "parameters": ["session_id", "address_id", "shipping_method"]
        },
        {
          "method": "PUT",
          "path": "/session/{session_id}/payment",
          "description": "Set payment method for checkout",
          "parameters": ["session_id", "payment_method_id"]
        },
        {
          "method": "POST",
          "path": "/session/{session_id}/complete",
          "description": "Complete checkout and create order",
          "parameters": ["session_id"]
        },
        {
          "method": "GET",
          "path": "/session/{session_id}/tax",
          "description": "Calculate tax for checkout session",
          "parameters": ["session_id"]
        }
      ]
    },
    "Order-API": {
      "description": "Order management and history endpoints",
      "base_path": "/orders",
      "endpoints": [
        {
          "method": "GET",
          "path": "/",
          "description": "Get user order history with pagination",
          "parameters": ["user_id", "status", "date_range", "page", "limit"]
        },
        {
          "method": "GET",
          "path": "/{order_id}",
          "description": "Get detailed order information and status",
          "parameters": ["order_id"]
        },
        {
          "method": "GET",
          "path": "/{order_id}/status",
          "description": "Get current order status and tracking information",
          "parameters": ["order_id"]
        },
        {
          "method": "GET",
          "path": "/{order_id}/tracking",
          "description": "Get shipment tracking details",
          "parameters": ["order_id"]
        },
        {
          "method": "POST",
          "path": "/{order_id}/cancel",
          "description": "Cancel order if still processing",
          "parameters": ["order_id", "reason"]
        }
      ]
    },
    "Profile-API": {
      "description": "User profile and address management endpoints", 
      "base_path": "/profile",
      "endpoints": [
        {
          "method": "GET",
          "path": "/",
          "description": "Get user profile information",
          "parameters": ["user_id"]
        },
        {
          "method": "PUT",
          "path": "/",
          "description": "Update user profile information",
          "parameters": ["user_id"]
        },
        {
          "method": "GET",
          "path": "/addresses",
          "description": "Get user's saved addresses",
          "parameters": ["user_id"]
        },
        {
          "method": "POST",
          "path": "/addresses",
          "description": "Add new address to user profile",
          "parameters": ["address_data"]
        },
        {
          "method": "PUT",
          "path": "/addresses/{address_id}",
          "description": "Update existing address",
          "parameters": ["address_id", "address_data"]
        },
        {
          "method": "DELETE",
          "path": "/addresses/{address_id}",
          "description": "Delete address from profile",
          "parameters": ["address_id"]
        }
      ]
    },
    "Seller-API": {
      "description": "Seller portal and listing management endpoints",
      "base_path": "/seller",
      "endpoints": [
        {
          "method": "GET",
          "path": "/dashboard",
          "description": "Get seller dashboard with metrics and overview",
          "parameters": ["seller_id"]
        },
        {
          "method": "GET",
          "path": "/listings",
          "description": "Get seller's product listings",
          "parameters": ["seller_id", "status", "page", "limit"]
        },
        {
          "method": "POST",
          "path": "/listings",
          "description": "Create new product listing",
          "parameters": ["product_data", "pricing", "inventory"]
        },
        {
          "method": "PUT",
          "path": "/listings/{listing_id}",
          "description": "Update existing product listing",
          "parameters": ["listing_id", "product_data", "pricing"]
        },
        {
          "method": "DELETE",
          "path": "/listings/{listing_id}",
          "description": "Remove product listing",
          "parameters": ["listing_id"]
        },
        {
          "method": "GET",
          "path": "/orders",
          "description": "Get orders for seller's products",
          "parameters": ["seller_id", "status", "date_range"]
        },
        {
          "method": "PUT",
          "path": "/inventory/{listing_id}",
          "description": "Update inventory levels for listing",
          "parameters": ["listing_id", "quantity", "warehouse_id"]
        }
      ]
    },
    "Review-API": {
      "description": "Product review and rating endpoints",
      "base_path": "/reviews",
      "endpoints": [
        {
          "method": "GET",
          "path": "/products/{product_id}",
          "description": "Get reviews for specific product",
          "parameters": ["product_id", "rating_filter", "page", "limit"]
        },
        {
          "method": "POST",
          "path": "/products/{product_id}",
          "description": "Submit new product review",
          "parameters": ["product_id", "rating", "title", "content", "user_id"]
        },
        {
          "method": "GET",
          "path": "/{review_id}",
          "description": "Get specific review details",
          "parameters": ["review_id"]
        },
        {
          "method": "PUT",
          "path": "/{review_id}",
          "description": "Update existing review",
          "parameters": ["review_id", "rating", "title", "content"]
        },
        {
          "method": "DELETE",
          "path": "/{review_id}",
          "description": "Delete review",
          "parameters": ["review_id"]
        }
      ]
    },
    "Search-API": {
      "description": "Product search and discovery endpoints",
      "base_path": "/search",
      "endpoints": [
        {
          "method": "GET",
          "path": "/products",
          "description": "Search products by keyword with filters and sorting",
          "parameters": ["query", "category", "price_range", "rating", "sort", "page", "limit"]
        },
        {
          "method": "GET",
          "path": "/suggestions",
          "description": "Get search suggestions and autocomplete",
          "parameters": ["partial_query", "limit"]
        },
        {
          "method": "GET",
          "path": "/trending",
          "description": "Get trending search terms and popular products",
          "parameters": ["category", "time_period"]
        }
      ]
    }
  }
} 