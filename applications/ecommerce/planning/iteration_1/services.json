{
  "infrastructure": {
    "description": "Core UI layer (no direct calls to internal services)",
    "services": [
      "Frontend"
    ]
  },
  "external_apis": {
    "description": "Public API entry points owning external endpoints",
    "services": [
      "Catalog-API",
      "Cart-API",
      "Checkout-API",
      "Order-API",
      "Profile-API",
      "Seller-API",
      "Review-API",
      "Search-API"
    ]
  },
  "product_catalog": {
    "description": "Product data, pricing, tags, and availability",
    "services": [
      "Product-Catalog-Service",
      "Catalog-Aggregator-Service",
      "Product-Metadata-Service",
      "Product-Image-Service",
      "Product-Attribute-Service",
      "Tag-Translation-Service",
      "Tag-Taxonomy-Service",
      "Price-Calc-Service",
      "Discount-Rule-Service",
      "Inventory-Avail-Service",
      "Product-Detail-Enrichment-Service"
    ]
  },
  "shopping_cart": {
    "description": "Cart persistence, totals, promotions",
    "services": [
      "ShoppingCart-Service",
      "Cart-State-Service",
      "Cart-Pricing-Service",
      "Promo-Eval-Service"
    ]
  },
  "search": {
    "description": "Keyword & facet search pipeline",
    "services": [
      "Product-Search-Service",
      "Search-Query-Service",
      "Search-Index-Service"
    ]
  },
  "checkout": {
    "description": "End-to-end checkout flow and order booking",
    "services": [
      "Checkout-Session-Service",
      "Cart-Validation-Service",
      "Checkout-Pricing-Service",
      "Tax-Calc-Service",
      "Inventory-Reserve-Service",
      "Checkout-Commit-Service",
      "Order-Booking-Service"
    ]
  },
  "payments": {
    "description": "Internal mock payment processing",
    "services": [
      "Payment-Authorization-Service",
      "Payment-Settlement-Service"
    ]
  },
  "shipping": {
    "description": "Shipping cost and rule evaluation",
    "services": [
      "Shipping-Estimator-Service",
      "Shipping-Rule-Engine-Service",
      "Geo-Region-Service",
      "Carrier-Cost-Service"
    ]
  },
  "orders": {
    "description": "Customer order history",
    "services": [
      "Order-History-Service"
    ]
  },
  "user_profile": {
    "description": "User profile and addresses",
    "services": [
      "Profile-Service",
      "Address-Mgmt-Service"
    ]
  },
  "seller": {
    "description": "Marketplace seller tooling",
    "services": [
      "Seller-Dashboard-Service",
      "Listing-Validation-Service",
      "Listing-Normalization-Service",
      "Listing-Image-Proc-Service",
      "Listing-Persist-Service",
      "Seller-Order-Service"
    ]
  },
  "reviews": {
    "description": "Product reviews storage and retrieval",
    "services": [
      "Review-Service",
      "Review-Write-Service",
      "Review-Read-Service"
    ]
  }
} 