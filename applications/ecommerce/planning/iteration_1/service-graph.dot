digraph ServiceGraph {
  rankdir=LR;
  // External API roots
  "Catalog-API" -> "Product-Catalog-Service";
  "Cart-API" -> "ShoppingCart-Service";
  "Checkout-API" -> "Checkout-Session-Service";
  "Order-API" -> "Order-History-Service";
  "Profile-API" -> "Profile-Service";
  "Seller-API" -> "Seller-Dashboard-Service";
  "Review-API" -> "Review-Service";
  "Search-API" -> "Product-Search-Service";

  // Frontend (UI only, no internal calls)
  "Frontend";

  // Catalog path
  "Product-Catalog-Service" -> "Catalog-Aggregator-Service";
  "Catalog-Aggregator-Service" -> "Product-Metadata-Service";
  "Catalog-Aggregator-Service" -> "Product-Image-Service";
  "Catalog-Aggregator-Service" -> "Product-Attribute-Service";
  "Catalog-Aggregator-Service" -> "Tag-Translation-Service";
  "Tag-Translation-Service" -> "Tag-Taxonomy-Service";
  "Catalog-Aggregator-Service" -> "Price-Calc-Service";
  "Price-Calc-Service" -> "Discount-Rule-Service";
  "Catalog-Aggregator-Service" -> "Inventory-Avail-Service";
  "Product-Catalog-Service" -> "Product-Detail-Enrichment-Service";

  // Cart path
  "ShoppingCart-Service" -> "Cart-State-Service";
  "Cart-State-Service" -> "Cart-Pricing-Service";
  "Cart-Pricing-Service" -> "Price-Calc-Service";
  "Cart-Pricing-Service" -> "Promo-Eval-Service";
  "Promo-Eval-Service" -> "Discount-Rule-Service";

  // Search path
  "Product-Search-Service" -> "Search-Query-Service";
  "Search-Query-Service" -> "Search-Index-Service";
  "Search-Index-Service" -> "Catalog-Aggregator-Service";

  // Checkout path
  "Checkout-Session-Service" -> "Cart-Validation-Service";
  // integrate Profile data
  "Checkout-Session-Service" -> "Profile-Service";
  "Cart-Validation-Service" -> "Promo-Eval-Service";
  "Checkout-Session-Service" -> "Checkout-Pricing-Service";
  "Checkout-Pricing-Service" -> "Tax-Calc-Service";
  "Checkout-Pricing-Service" -> "Price-Calc-Service";
  "Checkout-Pricing-Service" -> "Promo-Eval-Service";
  "Checkout-Session-Service" -> "Checkout-Commit-Service";
  "Checkout-Commit-Service" -> "Inventory-Reserve-Service";
  "Inventory-Reserve-Service" -> "Inventory-Avail-Service";
  "Checkout-Commit-Service" -> "Payment-Authorization-Service";
  "Payment-Authorization-Service" -> "Payment-Settlement-Service";
  "Checkout-Commit-Service" -> "Order-Booking-Service";

  // Shipping extensions
  "Order-Booking-Service" -> "Shipping-Estimator-Service";
  // integrate Address data
  "Shipping-Estimator-Service" -> "Address-Mgmt-Service";
  "Shipping-Estimator-Service" -> "Shipping-Rule-Engine-Service";
  "Shipping-Rule-Engine-Service" -> "Geo-Region-Service";
  "Shipping-Rule-Engine-Service" -> "Carrier-Cost-Service";

  // Orders
  "Order-History-Service" -> "Order-Booking-Service";

  // User profile
  "Profile-Service" -> "Address-Mgmt-Service";

  // Seller domain
  "Seller-Dashboard-Service" -> "Listing-Validation-Service";
  "Listing-Validation-Service" -> "Listing-Normalization-Service";
  "Listing-Normalization-Service" -> "Listing-Image-Proc-Service";
  "Listing-Image-Proc-Service" -> "Listing-Persist-Service";
  "Seller-Dashboard-Service" -> "Seller-Order-Service";
  "Seller-Order-Service" -> "Order-Booking-Service";
  "Listing-Validation-Service" -> "Inventory-Avail-Service";
  "Listing-Validation-Service" -> "Price-Calc-Service";

  // Reviews
  "Review-Service" -> "Review-Write-Service";
  "Review-Write-Service" -> "Review-Read-Service";

  // Product Detail enrichment
  "Product-Detail-Enrichment-Service" -> "Catalog-Aggregator-Service";
  "Product-Detail-Enrichment-Service" -> "Review-Read-Service";
} 