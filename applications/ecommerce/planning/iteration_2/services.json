{
  "infrastructure": {
    "description": "Core UI layer (no direct calls to internal services)",
    "services": [
      "Frontend"
    ]
  },
  "external_apis": {
    "description": "Public API entry points owning external endpoints",
    "services": [
      "Catalog-API",
      "Cart-API", 
      "Checkout-API",
      "Order-API",
      "Profile-API",
      "Seller-API",
      "Review-API",
      "Search-API"
    ]
  },
  "product_catalog": {
    "description": "Consolidated product resolution and content assembly",
    "core_resolution": {
      "description": "Product identification and configuration",
      "services": [
        "Product-Resolution-Service",
        "Product-Configuration-Service"
      ]
    },
    "metadata_enrichment": {
      "description": "Product data aggregation and content assembly",
      "services": [
        "Product-Metadata-Aggregator",
        "Product-Content-Assembly-Service",
        "Tag-Taxonomy-Service"
      ]
    },
    "availability": {
      "description": "Consolidated inventory and availability management",
      "services": [
        "Inventory-Orchestrator",
        "Inventory-Analysis-Service",
        "Backorder-Analysis-Service"
      ]
    }
  },
  "dynamic_pricing": {
    "description": "Market-based pricing without personalization",
    "services": [
      "Price-Orchestration-Service",
      "Market-Intelligence-Service",
      "Price-Calculation-Service",
      "Price-Assembly-Service",
      "Discount-Strategy-Service"
    ]
  },
  "shopping_cart": {
    "description": "Consolidated cart management with pricing",
    "services": [
      "Cart-Orchestration-Service",
      "Cart-Management-Service",
      "Cart-Pricing-Service"
    ]
  },
  "search": {
    "description": "Consolidated search processing and results",
    "services": [
      "Search-Orchestration-Service",
      "Search-Processing-Service",
      "Search-Results-Service"
    ]
  },
  "checkout": {
    "description": "Complex checkout with validation and coordination",
    "session_management": {
      "description": "Consolidated checkout session and validation",
      "services": [
        "Checkout-Orchestration-Service",
        "Checkout-Validation-Service",
        "Address-Validation-Service"
      ]
    },
    "pricing_coordination": {
      "description": "Consolidated tax calculation and payment processing",
      "services": [
        "Checkout-Pricing-Service",
        "Tax-Service",
        "Tax-Assembly-Service",
        "Payment-Processing-Service",
        "Payment-Settlement-Service"
      ]
    }
  },
  "order_management": {
    "description": "Complex order processing and fulfillment",
    "order_coordination": {
      "description": "Consolidated order creation and processing",
      "services": [
        "Order-Orchestration-Service",
        "Order-Validation-Service"
      ]
    },
    "fulfillment_planning": {
      "description": "Consolidated fulfillment strategy and execution",
      "services": [
        "Fulfillment-Planning-Service",
        "Order-Batching-Service",
        "Resource-Allocation-Service"
      ]
    },
    "shipping_coordination": {
      "description": "Consolidated shipping and delivery coordination",
      "services": [
        "Shipping-Orchestration-Service",
        "Carrier-Route-Service",
        "Shipment-Delivery-Service"
      ]
    },
    "order_tracking": {
      "description": "Order history and status management",
      "services": [
        "Order-History-Service",
        "Order-Status-Service"
      ]
    }
  },
  "user_profile": {
    "description": "Consolidated user profile and address processing",
    "services": [
      "Profile-Management-Service",
      "Address-Processing-Service",
      "Address-Standardization-Service",
      "Geographic-Classification-Service"
    ]
  },
  "seller": {
    "description": "Seller tools with listing management",
    "listing_management": {
      "description": "Consolidated listing creation and management",
      "services": [
        "Seller-Portal-Service",
        "Listing-Processing-Service",
        "Listing-Publication-Service"
      ]
    },
    "seller_operations": {
      "description": "Seller order and inventory management",
      "services": [
        "Seller-Order-Management-Service",
        "Seller-Inventory-Service"
      ]
    }
  },
  "reviews": {
    "description": "Consolidated review processing",
    "services": [
      "Review-Processing-Service",
      "Review-Assembly-Service"
    ]
  }
} 